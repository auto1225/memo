{
  "manifest_version": 3,
  "name": "__MSG_app_name__",
  "short_name": "__MSG_app_short_name__",
  "version": "1.0.1",
  "description": "__MSG_app_description__",
  "default_locale": "ko",
  "homepage_url": "https://justanotepad.com",
  "author": "JustANotepad",
  "action": {
    "default_title": "JustANotepad에 저장",
    "default_popup": "popup.html",
    "default_icon": {
      "16":  "icons/icon-16.png",
      "32":  "icons/icon-32.png",
      "48":  "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "icons": {
    "16":  "icons/icon-16.png",
    "32":  "icons/icon-32.png",
    "48":  "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": ["activeTab", "scripting", "storage", "contextMenus", "notifications"],
  "host_permissions": [
    "https://rbscvtnfveakwjwrteux.supabase.co/*",
    "https://justanotepad.com/*",
    "<all_urls>"
  ],
  "background": { "service_worker": "background.js", "type": "module" },
  "externally_connectable": {
    "matches": [
      "https://justanotepad.com/*",
      "https://www.justanotepad.com/*",
      "http://localhost:*/*"
    ]
  },
  "commands": {
    "clip-page": {
      "suggested_key": { "default": "Ctrl+Shift+J", "mac": "Command+Shift+J" },
      "description": "현재 페이지를 JustANotepad에 저장"
    }
  }
}
