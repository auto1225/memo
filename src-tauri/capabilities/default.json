{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "JustANotepad 기본 권한",
  "windows": ["main"],
  "remote": {
    "urls": [
      "https://justanotepad.com/**",
      "https://www.justanotepad.com/**"
    ]
  },
  "permissions": [
    "core:default",
    "core:window:default",
    "core:webview:default",
    "core:app:default",
    "core:event:default",
    "core:path:default",
    "core:window:allow-show",
    "core:window:allow-hide",
    "core:window:allow-close",
    "core:window:allow-destroy",
    "core:window:allow-minimize",
    "core:window:allow-unminimize",
    "core:window:allow-set-focus",
    "core:window:allow-set-always-on-top",
    "core:window:allow-set-always-on-bottom",
    "core:window:allow-set-position",
    "core:window:allow-set-size",
    "core:window:allow-start-dragging",
    "core:webview:allow-create-webview-window",
    "core:webview:allow-webview-close",
    "core:window:allow-set-decorations",
    "core:window:allow-set-shadow",
    "core:window:allow-toggle-maximize",
    "core:window:allow-is-maximized",
    "core:window:allow-unmaximize",
    "core:window:allow-maximize",
    "core:window:allow-start-resize-dragging",
    "shell:allow-open",
    "log:default",
    "updater:default",
    "process:default",
    "process:allow-restart",
    "process:allow-exit",
    "autostart:default",
    "autostart:allow-enable",
    "autostart:allow-disable",
    "autostart:allow-is-enabled",
    "dialog:default",
    "dialog:allow-save",
    "dialog:allow-open",
    "dialog:allow-message",
    "dialog:allow-ask",
    "dialog:allow-confirm",
    "fs:default",
    "fs:allow-write-text-file",
    "fs:allow-write-file",
    "fs:allow-read-text-file",
    "fs:allow-read-file",
    "fs:scope-home-recursive",
    "fs:scope-document-recursive",
    "fs:scope-download-recursive",
    "fs:scope-desktop-recursive",
    "fs:scope-picture-recursive",
    "fs:scope-video-recursive",
    "fs:scope-audio-recursive"
  ]
}
